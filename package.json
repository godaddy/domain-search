{
  "name": "domain-search",
  "version": "5.0.1",
  "description": "React-based domain search widget used for designing and building custom GoDaddy reseller storefronts",
  "main": "dist/domain-search.umd.js",
  "module": "dist/domain-search.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/domain-search.es.js",
      "require": "./dist/domain-search.umd.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --emitDeclarationOnly --declaration --outDir dist",
    "build:demo": "vite build --config vite.demo.config.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/godaddy/domain-search"
  },
  "homepage": "https://godaddy.github.io/domain-search",
  "author": "GoDaddy.com Operating Company, LLC",
  "keywords": [
    "domains",
    "domain search",
    "reseller",
    "npm",
    "react"
  ],
  "license": "MIT",
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^15.0.6",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "jsdom": "^29.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.4.5",
    "vite": "^8.0.5",
    "vitest": "^4.1.2"
  }
}
